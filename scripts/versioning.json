{
  "$schema": "./versioning.schema.json",
  "schema_version": 1,
  "_comment": "Shipyard versioning gate. The CLI is now a Shipyard binary versioned from Cargo.toml; plugin files remain git-delivered and independently versioned.",

  "surfaces": {
    "cli": {
      "label": "Shipyard CLI",
      "version_files": [
        {
          "path": "Cargo.toml",
          "kind": "regex",
          "pattern": "(?ms)^\\[package\\].*?^version\\s*=\\s*\"([^\"]+)\""
        }
      ],
      "trigger_paths": [
        "Cargo.toml",
        "Cargo.lock",
        "src/**/*.rs",
        "install.sh",
        ".github/workflows/ci.yml",
        ".github/workflows/release.yml",
        ".github/workflows/auto-release.yml",
        ".github/workflows/sandbox-e2e.yml",
        ".github/workflows/package-smoke.yml",
        ".github/workflows/cloud-live-smoke.yml",
        "scripts/package_release.py",
        "scripts/release_macos_local.py",
        "scripts/release-macos-local.sh",
        "scripts/ci_matrix.py",
        "scripts/finish_line_status.py",
        "tools/sandbox-e2e/**"
      ],
      "public_api_paths": [
        "src/app/cli.rs",
        "src/app/**/*.rs",
        "src/daemon_ipc.rs",
        "src/daemon_runtime.rs",
        "src/paths.rs",
        "src/config.rs",
        "src/init_config.rs"
      ],
      "internal_only_paths": [
        "scripts/test_*.py",
        "tools/sandbox-e2e/**"
      ],
      "auto_apply_patch": true,
      "changelog": "CHANGELOG.md"
    },

    "plugin": {
      "label": "Shipyard Claude plugin",
      "version_files": [
        { "path": ".claude-plugin/plugin.json", "kind": "json_field", "field": "version" }
      ],
      "trigger_paths": [
        ".claude-plugin/**",
        "commands/**",
        "skills/**",
        "agents/**",
        "hooks/**"
      ],
      "public_api_paths": [
        ".claude-plugin/plugin.json",
        "commands/**"
      ],
      "internal_only_paths": [
        "hooks/*.sh"
      ]
    }
  },

  "skills": {
    "skills_dir": "skills",
    "path_map": "scripts/skill_path_map.json"
  },

  "generated_globs": [
    "dist/**",
    "build/**",
    "target/**",
    "coverage/**",
    "*.egg-info/**",
    "**/*.generated.*",
    "node_modules/**"
  ],

  "trailers": {
    "version_bump": "Version-Bump",
    "skill_update": "Skill-Update",
    "release": "Release"
  }
}
